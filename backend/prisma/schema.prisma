// Prisma schema for the NGO website
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Admin {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
}

model Program {
  id          Int      @id @default(autoincrement())
  title       String
  slug        String   @unique
  summary     String
  description String
  category    String   @default("Community")
  image       String?
  icon        String?  @default("HeartHandshake")
  featured    Boolean  @default(false)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Article {
  id        Int      @id @default(autoincrement())
  title     String
  slug      String   @unique
  excerpt   String
  content   String
  image     String?

  /// Optional external “detailed” URL (Google Drive, report link, etc.)
  driveLink String?

  author    String   @default("NGO Team")
  category  String   @default("Awareness")
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


model Gallery {
  id        Int      @id @default(autoincrement())
  title     String?
  image     String
  category  String   @default("Events")
  createdAt DateTime @default(now())
}

model Contact {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  phone     String?
  subject   String?
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Testimonial {
  id        Int      @id @default(autoincrement())
  name      String
  role      String?
  quote     String
  image     String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

// Single-row key/value store for editable homepage / site content
model SiteContent {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model Achievement {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  image       String?
  createdAt   DateTime @default(now())
}

model Volunteer {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  phone     String
  message   String
  interest  String?
  status    String   @default("pending") // pending, approved, rejected
  createdAt DateTime @default(now())
}
